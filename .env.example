# ─── DATABASE ────────────────────────────────────────────────────────────────
# Local PostgreSQL (Docker)
DATABASE_URL=postgresql://mavericks:mavericks_dev_password@localhost:5432/mavericks_inventory
# Azure PostgreSQL (production)
# DATABASE_URL=postgresql://USER:PASSWORD@YOUR_SERVER.postgres.database.azure.com:5432/mavericks_inventory?sslmode=require

# ─── AUTHENTICATION ───────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=8080
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
NODE_ENV=development

# ─── AZURE OPENAI (GPT-4o) ───────────────────────────────────────────────────
# Get from: Azure Portal → Azure OpenAI resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com/
AZURE_OPENAI_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01
# NOTE: If these are missing, all AI agents fall back to rule-based logic automatically.

# ─── AZURE BLOB STORAGE ──────────────────────────────────────────────────────
# Get from: Azure Portal → Storage Account → Access keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=mavericks-uploads
# NOTE: If missing, files are stored locally in /tmp/uploads/ instead.

# ─── AZURE AI SEARCH ─────────────────────────────────────────────────────────
# Get from: Azure Portal → AI Search resource → Keys → Admin key
AZURE_SEARCH_ENDPOINT=https://YOUR_SEARCH_SERVICE.search.windows.net
AZURE_SEARCH_KEY=your_azure_search_admin_key_here
AZURE_SEARCH_INDEX=mavericks-stocks
# NOTE: If missing, search falls back to PostgreSQL ILIKE queries.

# ─── EMAIL (optional — notifications) ────────────────────────────────────────
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_email_password
# SMTP_FROM=noreply@mavericks.hexaware.com
